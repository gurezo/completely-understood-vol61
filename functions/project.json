{
  "name": "functions",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/functions/lib"],
      "options": {
        "command": "npm run build",
        "cwd": "functions"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run lint",
        "cwd": "functions"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run serve",
        "cwd": "functions"
      }
    }
  },
  "tags": []
}
